{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --import tsx src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node build/server.js",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "4.0.0-beta.13",
    "@workspace/browser-agent": "workspace:*",
    "ai": "7.0.0-beta.33",
    "dotenv": "16.4.5",
    "express": "5.0.1"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "20.17.24",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "4.19.2",
    "typescript": "5.8.3"
  }
}
